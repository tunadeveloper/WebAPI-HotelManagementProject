@using HotelManagement.DataTransferObjectLayer.DTOs.MessageDTOs
@using HotelManagement.DataTransferObjectLayer.DTOs.RoomDTOs
@using HotelManagement.DataTransferObjectLayer.DTOs.SubscribeDTOs

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-lg-3 col-sm-6 d-flex align-items-stretch">
        <div class="card w-100">
            <div class="card-body">
                <h6 class="fw-semibold mb-1">Toplam Oda</h6>
                <h4 class="fw-semibold mb-0">@ViewBag.RoomCount</h4>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6 d-flex align-items-stretch">
        <div class="card w-100">
            <div class="card-body">
                <h6 class="fw-semibold mb-1">Toplam Rezervasyon</h6>
                <h4 class="fw-semibold mb-0">@ViewBag.BookingCount</h4>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6 d-flex align-items-stretch">
        <div class="card w-100">
            <div class="card-body">
                <h6 class="fw-semibold mb-1">Kullanıcı</h6>
                <h4 class="fw-semibold mb-0">@ViewBag.UserCount</h4>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6 d-flex align-items-stretch">
        <div class="card w-100">
            <div class="card-body">
                <h6 class="fw-semibold mb-1">Mesaj</h6>
                <h4 class="fw-semibold mb-0">@ViewBag.MessageCount</h4>
            </div>
        </div>
    </div>
</div>
<script>
    window.dashboardData = @Html.Raw(ViewBag.DashboardDataJson ?? "{}");
</script>
<div class="row">
                        <div class="col-lg-8 d-flex align-items-strech">
                            <div class="card w-100">
                                <div class="card-body">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <div class="">
                                            <h5 class="card-title fw-semibold">Günlere Göre Mesajlar</h5>
                                        </div>
                                        <div class="dropdown">
                                            <button id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false"
                                                    class="rounded-circle btn-transparent rounded-circle btn-sm px-1 btn shadow-none">
                                                <i class="ti ti-dots-vertical fs-7 d-block"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuButton1">
                                                <li><a class="dropdown-item" href="javascript:void(0)">Detay</a></li>
                                                <li><a class="dropdown-item" href="javascript:void(0)">Yenile</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div id="profit"></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="row">
                                <div class="col-lg-12 col-sm-6">
                                    <div class="card overflow-hidden">
                                        <div class="card-body p-4">
                                            <h5 class="card-title mb-10 fw-semibold">Rezervasyon Durumları</h5>
                                            <div class="row align-items-center">
                                                <div class="col-7">
                                                    <h4 class="fw-semibold mb-3">@ViewBag.BookingCount</h4>
                                                    <div class="d-flex align-items-center mb-2">
                                                        <span class="me-1 rounded-circle bg-light-warning round-20 d-flex align-items-center justify-content-center">
                                                            <i class="ti ti-clock text-warning"></i>
                                                        </span>
                                                        <p class="text-dark me-1 fs-3 mb-0">Beklemede:</p>
                                                        <p class="fs-3 mb-0">@ViewBag.PendingBookingCount</p>
                                                    </div>
                                                    <div class="d-flex align-items-center mb-2">
                                                        <span class="me-1 rounded-circle bg-light-success round-20 d-flex align-items-center justify-content-center">
                                                            <i class="ti ti-check text-success"></i>
                                                        </span>
                                                        <p class="text-dark me-1 fs-3 mb-0">Onaylı:</p>
                                                        <p class="fs-3 mb-0">@ViewBag.ApprovedBookingCount</p>
                                                    </div>
                                                    <div class="d-flex align-items-center mb-2">
                                                        <span class="me-1 rounded-circle bg-light-danger round-20 d-flex align-items-center justify-content-center">
                                                            <i class="ti ti-x text-danger"></i>
                                                        </span>
                                                        <p class="text-dark me-1 fs-3 mb-0">İptal:</p>
                                                        <p class="fs-3 mb-0">@ViewBag.CanceledBookingCount</p>
                                                    </div>
                                                    <div class="d-flex align-items-center">
                                                        <div class="me-3">
                                                            <span class="round-8 bg-primary rounded-circle me-2 d-inline-block"></span>
                                                            <span class="fs-2">Hizmet (@ViewBag.ServiceCount)</span>
                                                        </div>
                                                        <div>
                                                            <span class="round-8 bg-danger rounded-circle me-2 d-inline-block"></span>
                                                            <span class="fs-2">Mesaj (@ViewBag.MessageCount)</span>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-5">
                                                    <div class="d-flex justify-content-center">
                                                        <div id="grade"></div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-sm-6">
                                    <div class="card">
                                        <div class="card-body">
                                            <div class="row alig n-items-start">
                                                <div class="col-8">
                                                    <h5 class="card-title mb-10 fw-semibold">Ortalama Oda Fiyatı</h5>
                                                    <h4 class="fw-semibold mb-3">@(ViewBag.AverageRoomPrice + " ₺")</h4>
                                                    <div class="d-flex align-items-center pb-1">
                                                        <span class="me-2 rounded-circle bg-light-danger round-20 d-flex align-items-center justify-content-center">
                                                            <i class="ti ti-arrows-minimize text-danger"></i>
                                                        </span>
                                                        <p class="text-dark me-1 fs-3 mb-0">Min:</p>
                                                        <p class="fs-3 mb-0">@(ViewBag.MinRoomPrice + " ₺")</p>
                                                    </div>
                                                    <div class="d-flex align-items-center pb-1">
                                                        <span class="me-2 rounded-circle bg-light-success round-20 d-flex align-items-center justify-content-center">
                                                            <i class="ti ti-arrows-maximize text-success"></i>
                                                        </span>
                                                        <p class="text-dark me-1 fs-3 mb-0">Max:</p>
                                                        <p class="fs-3 mb-0">@(ViewBag.MaxRoomPrice + " ₺")</p>
                                                    </div>
                                                </div>
                                                <div class="col-4">
                                                    <div class="d-flex justify-content-end">
                                                        <div class="text-white bg-danger rounded-circle p-6 d-flex align-items-center justify-content-center">
                                                            <i class="ti ti-currency-dollar fs-6"></i>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div id="earning"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
<div class="row">
                        <div class="col-lg-4 d-flex align-items-stretch">
                            <div class="card w-100">
                                <div class="card-body p-4">
                                    <div class="mb-4">
                                        <h5 class="card-title fw-semibold">Son Aboneler</h5>
                                    </div>
                                    <ul class="timeline-widget mb-0 position-relative mb-n5">
                                        @foreach (var item in (ViewBag.LastSubscribers as List<ResultSubscribeDTO>))
                                        {
                                            <li class="timeline-item d-flex position-relative overflow-hidden">
                                                <div class="timeline-time text-dark flex-shrink-0 text-end">#@item.Id</div>
                                                <div class="timeline-badge-wrap d-flex flex-column align-items-center">
                                                    <span class="timeline-badge border-2 border border-primary flex-shrink-0 my-2"></span>
                                                    <span class="timeline-badge-border d-block flex-shrink-0"></span>
                                                </div>
                                                <div class="timeline-desc fs-3 text-dark mt-n1">@item.Email</div>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-8 d-flex align-items-stretch">
                            <div class="card w-100">
                                <div class="card-body p-4">
                                    <div class="d-flex mb-4 justify-content-between align-items-center">
                                        <h5 class="mb-0 fw-bold">Son Mesajlar</h5>

                                        <div class="dropdown">
                                            <button id="dropdownMenuButton1" data-bs-toggle="dropdown" aria-expanded="false"
                                                    class="rounded-circle btn-transparent rounded-circle btn-sm px-1 btn shadow-none">
                                                <i class="ti ti-dots-vertical fs-7 d-block"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuButton1">
                                                <li><a class="dropdown-item" href="#">Action</a></li>
                                                <li>
                                                    <a class="dropdown-item" href="#">Another action</a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" href="#">Something else here</a>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>

                                    <div class="table-responsive" data-simplebar>
                                        <table class="table table-borderless align-middle text-nowrap">
                                            <thead>
                                                <tr>
                                                    <th scope="col">Gönderen</th>
                                                    <th scope="col">Konu</th>
                                                    <th scope="col">Tarih</th>
                                                    <th scope="col">Durum</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in (ViewBag.LastMessages as List<ResultMessageDTO>))
                                                {
                                                    <tr>
                                                        <td>
                                                            <div class="d-flex align-items-center">
                                                                <div class="me-4">
                                                                    <img src="/src/assets/images/profile/user1.jpg" width="50" class="rounded-circle" alt="" />
                                                                </div>
                                                                <div>
                                                                    <h6 class="mb-1 fw-bolder">@item.NameSurname</h6>
                                                                    <p class="fs-3 mb-0">@item.Email</p>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <p class="fs-3 fw-normal mb-0">@item.Subject</p>
                                                        </td>
                                                        <td>
                                                            <p class="fs-3 fw-normal mb-0">@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                                                        </td>
                                                        <td>
                                                            <span class="badge bg-light-success rounded-pill text-success px-3 py-2 fs-3">Yeni</span>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
<div class="row">
    <div class="col-12">
        <h5 class="mb-3 fw-bold">Son Eklenen Oteller</h5>
    </div>

    @foreach (var room in (ViewBag.LastRooms as List<ResultRoomDTO>))
    {
        <div class="col-sm-6 col-xl-3">
            <div class="card overflow-hidden">
                <div class="position-relative">
                    <a href="javascript:void(0)">
                        <img src="@room.CoverImage"
                             class="card-img-top rounded-0" alt="Otel">
                    </a>
                </div>
                <div class="card-body pt-3 p-4">
                    <h6 class="fw-semibold fs-4">@room.Title</h6>
                    <div class="d-flex align-items-center justify-content-between">
                        <h6 class="fw-semibold fs-4 mb-0">@($"{room.Price} ₺")</h6>
                        <span class="fs-3 text-muted">Oda No: @room.RoomNumber</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
