@using HotelManagement.DataTransferObjectLayer.DTOs.WorkLocationDTOs
@model List<ResultWorkLocationDTO>
@{
    ViewData["Title"] = "Çalışma Lokasyonları";
    Layout = "~/Areas/Admin/Views/_AdminLayout.cshtml";
}

<div class="col-lg-12 d-flex align-items-stretch">
    <div class="card w-100">
        <div class="card-body p-4">
            <div class="d-flex mb-4 justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Çalışma Lokasyonları</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-borderless align-middle text-nowrap">
                    <thead>
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">Ad</th>
                            <th scope="col">Şehir</th>
                            <th scope="col">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="fs-3 fw-normal">@item.Id</span></td>
                                <td><p class="fs-3 fw-normal mb-0">@item.Name</p></td>
                                <td><p class="fs-3 fw-normal mb-0">@item.City</p></td>
                                <td>
                                    <a href="/Admin/WorkLocation/DeleteWorkLocation/@item.Id" class="btn btn-danger btn-sm">Sil</a>
                                    <a href="/Admin/WorkLocation/UpdateWorkLocation/@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <a href="/Admin/WorkLocation/InsertWorkLocation" class="btn btn-success">Yeni Lokasyon</a>
        </div>
    </div>
</div>
