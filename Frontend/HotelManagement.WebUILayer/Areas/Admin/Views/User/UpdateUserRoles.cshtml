@using HotelManagement.DataTransferObjectLayer.DTOs.AppRoleDTO
@{
    ViewData["Title"] = "Kullanıcı Rolleri";
    Layout = "~/Areas/Admin/Views/_AdminLayout.cshtml";
    var allRoles = ViewBag.AllRoles as List<ResultAppRoleDTO>;
    var userRoleNames = ViewBag.UserRoleNames as List<string>;
    var userId = ViewBag.UserId as int? ?? 0;
}

<div class="mb-3">
    <h4 class="fs-6 mb-0">Kullanıcılar</h4>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Admin/Dashboard/Index">Ana Sayfa</a></li>
            <li class="breadcrumb-item"><a href="/Admin/User/Index">Kullanıcı Listesi</a></li>
            <li class="breadcrumb-item active">Rol Güncelle</li>
        </ol>
    </nav>
</div>

<div class="col-lg-12 d-flex align-items-stretch">
    <div class="card w-100">
        <div class="card-body p-4">
            <h5 class="mb-4 fw-bold">Kullanıcı Rolleri</h5>

            <form method="post" action="/Admin/User/UpdateUserRoles">
                <input type="hidden" name="userId" value="@userId" />
                <div class="mb-4">
                    <label class="form-label">Roller</label>
                    <div class="border rounded p-3">
                        @foreach (var role in allRoles)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="roleNames" value="@role.Name" id="role_@role.Id"
                                       @(userRoleNames.Contains(role.Name ?? "") ? "checked" : "") />
                                <label class="form-check-label" for="role_@role.Id">@(role.Name ?? "-")</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                    <a href="/Admin/User/Index" class="btn btn-outline-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>
